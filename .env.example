# ── Backend environment (copy to ".env" and fill in) ─────────────────────────
# This file is a template. Real ".env" is gitignored and never committed.

# Google Gemini API key — get one free at https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Primary model. Agents auto-fall back across the list below on rate-limits (429).
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash,gemini-2.0-flash-lite

# ── Optional integrations (leave blank if unused) ────────────────────────────
GROQ_API_KEY=
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
AZURE_SEARCH_ENDPOINT=
AZURE_SEARCH_KEY=
